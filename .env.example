# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPABASE: Used for Supabase SDK (Auth, Storage, etc.)
VITE_SUPABASE_URL="https://rhhgaaonhxkrojqwyihy.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJoaGdhYW9uaHhrcm9qcXd5aWh5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzNzI1NTMsImV4cCI6MjA5MTk0ODU1M30.0nH2wCIBz8z_M-cLrNCpJeEh_mnCXFDaJSRQYyJOoHA"

# DATABASE_URL: Supabase connection string (usually with transaction pooling, port 6543 or 5432)
# postgres://postgres.[USER]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true
DATABASE_URL=

# DIRECT_URL: Supabase direct connection string (essential for migrations, port 5432)
DIRECT_URL="postgresql://postgres.USER:PASSWORD@HOST:5432/postgres"
